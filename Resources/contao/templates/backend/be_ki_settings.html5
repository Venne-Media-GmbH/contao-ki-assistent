                                <span class="dot"></span>
                                <?= $this->kiEnabled ? 'Aktiv' : 'Inaktiv' ?>
                            </span>
                        </div>
                        <label class="ki-toggle">
                            <input type="checkbox" name="ki_enabled" value="1" <?= $this->kiEnabled ? 'checked' : '' ?>>
