                                <div style="max-height:400px;overflow-y:auto;border:1px solid rgba(128,128,128,.25);border-radius:8px;padding:12px">
                                    <div style="margin-bottom:8px">
                                        <button type="button" onclick="document.querySelectorAll('.ki-page-cb').forEach(function(c){c.checked=true})" style="font-size:11px;cursor:pointer;background:none;border:1px solid rgba(128,128,128,.3);border-radius:4px;padding:2px 8px;margin-right:4px">Alle auswählen</button>
                                        <button type="button" onclick="document.querySelectorAll('.ki-page-cb').forEach(function(c){c.checked=false})" style="font-size:11px;cursor:pointer;background:none;border:1px solid rgba(128,128,128,.3);border-radius:4px;padding:2px 8px">Alle abwählen</button>
                                    </div>
                                    <?php
                                    $selectedIds = is_array($this->kiCrawlPageIds) ? $this->kiCrawlPageIds : [];
                                    foreach ($this->pageTree as $page):
                                        $indent = $page['level'] * 20;
                                        $isSelected = in_array($page['id'], $selectedIds, true);
                                        $isRegular = in_array($page['type'], ['regular', 'forward', 'redirect'], true);
                                        $typeLabel = match($page['type']) {
                                            'root' => '🌐',
                                            'regular' => '📄',
                                            'forward' => '↗️',
                                            'redirect' => '🔗',
                                            default => '📁',
                                        };
                                    ?>
                                    <label style="display:flex;align-items:center;gap:6px;padding:3px 0;padding-left:<?= $indent ?>px;cursor:<?= $isRegular ? 'pointer' : 'default' ?>;font-size:13px">
                                        <?php if ($isRegular): ?>
                                            <input type="checkbox" name="ki_crawl_pages[]" value="<?= $page['id'] ?>" class="ki-page-cb" <?= $isSelected ? 'checked' : '' ?> style="margin:0">
                                        <?php else: ?>
                                            <span style="width:13px;display:inline-block"></span>
                                        <?php endif; ?>
                                        <span><?= $typeLabel ?></span>
                                        <span style="font-weight:<?= $page['type'] === 'root' ? '700' : '400' ?>"><?= \Contao\StringUtil::specialchars($page['title']) ?></span>
                                        <?php if ($page['alias']): ?>
                                            <span style="font-size:11px;opacity:.5;font-family:monospace">/<?= \Contao\StringUtil::specialchars($page['alias']) ?></span>
                                        <?php endif; ?>
                                    </label>
                                    <?php endforeach; ?>
                                </div>
                                <p class="help" style="margin-top:8px">Ausgewählte Seiten werden beim nächsten Indizieren gecrawlt und in die KI-Wissensbasis aufgenommen.</p>
                            <?php else: ?>
                                <p style="font-size:13px;opacity:.6">Kein Seitenbaum verfügbar. Stellen Sie sicher, dass mindestens eine Root-Seite existiert.</p>
                            <?php endif; ?>
                        </div>
                    </div>

                    <div style="margin-top:8px">
                        <button type="submit" class="ki-btn">Einstellungen speichern</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    function updatePreview() {
        var color = document.getElementById('ki_color').value || '#10b981';
        var icon = document.getElementById('ki_bubble_icon').value;
        var title = document.getElementById('ki_title').value || 'KI Assistent';
        var logoUrl = document.getElementById('ki_logo_url').value;

        document.getElementById('preview_bubble').style.background = color;
        document.getElementById('preview_header').style.background = color;
        document.getElementById('preview_title').textContent = title;

        var logoImg = document.getElementById('preview_logo_img');
        var hasLogo = logoUrl && logoUrl.trim() !== '';
        ['chat','sparkle','bot'].forEach(function(i) {
            document.getElementById('icon_' + i).style.display = (!hasLogo && i === icon) ? '' : 'none';
        });
        if (hasLogo) {
            logoImg.src = logoUrl;
            logoImg.style.display = '';
        } else {
            logoImg.style.display = 'none';
        }
    }

    function updateLogoPreview() {
        var url = document.getElementById('ki_logo_url').value.trim();
        var box = document.getElementById('logo_preview');
        if (url) {
            box.innerHTML = '<img src="' + url.replace(/"/g,'') + '" alt="">';
        } else {
            box.innerHTML = '<span class="empty">kein Logo</span>';
        }
    }

    function onLogoFileSelected(input) {
        if (!input.files || !input.files[0]) return;
        var file = input.files[0];
        document.getElementById('ki_logo_file_name').textContent = file.name;
        document.getElementById('ki_logo_remove').value = '0';
        // Show local preview immediately
        var reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('logo_preview').innerHTML = '<img src="' + e.target.result + '" alt="">';
        };
        reader.readAsDataURL(file);
    }

    function removeLogo() {
        document.getElementById('ki_logo_url').value = '';
        document.getElementById('ki_logo_remove').value = '1';
        document.getElementById('ki_logo_file').value = '';
        document.getElementById('ki_logo_file_name').textContent = '';
        document.getElementById('logo_preview').innerHTML = '<span class="empty">kein Logo</span>';
        updatePreview();
    }

    function toggleHoursDisabled() {
        // Visual only — server checks hoursEnabled flag
    }

    function toggleDayInputs(day) {
        var cb = document.querySelector('input[name="ki_hours[' + day + '][open]"]');
        document.getElementById('from_' + day).disabled = !cb.checked;
        document.getElementById('to_' + day).disabled = !cb.checked;
        var status = document.getElementById('status_' + day);
        if (status) status.textContent = cb.checked ? 'geöffnet' : 'geschlossen';
    }

    updatePreview();
    </script>
