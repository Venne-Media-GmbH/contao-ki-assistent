                    <!-- Design -->
                    <div class="ki-card">
                        <h3>Design</h3>
                        <p class="desc">Passen Sie das Aussehen des Chat-Widgets an Ihre Webseite an.</p>

                        <div class="ki-row">
                            <div class="ki-field">
                                <label for="ki_color">Widget-Farbe</label>
                                <div class="ki-color-row">
                                    <input type="color" id="ki_color_picker" class="ki-color-picker"
                                        value="<?= \Contao\StringUtil::specialchars($this->kiColor ?? '#10b981') ?>"
                                        oninput="document.getElementById('ki_color').value=this.value;updatePreview()">
                                    <input type="text" name="ki_color" id="ki_color" class="ki-input ki-input-mono" style="max-width:120px"
                                        value="<?= \Contao\StringUtil::specialchars($this->kiColor ?? '#10b981') ?>"
                                        pattern="^#[0-9a-fA-F]{6}$" placeholder="#10b981"
                                        oninput="document.getElementById('ki_color_picker').value=this.value;updatePreview()">
                                </div>
                            </div>
                            <div class="ki-field">
                                <label for="ki_position">Position</label>
                                <select name="ki_position" id="ki_position" class="ki-select" onchange="updatePreview()">
                                    <option value="bottom-right" <?= ($this->kiPosition ?? '') === 'bottom-right' ? 'selected' : '' ?>>Unten rechts</option>
                                    <option value="bottom-left" <?= ($this->kiPosition ?? '') === 'bottom-left' ? 'selected' : '' ?>>Unten links</option>
                                </select>
                            </div>
                        </div>

                        <div class="ki-row">
                            <div class="ki-field">
                                <label for="ki_title">Widget-Titel</label>
                                <input type="text" name="ki_title" id="ki_title" class="ki-input"
                                    value="<?= \Contao\StringUtil::specialchars($this->kiTitle ?? 'KI Assistent') ?>"
                                    placeholder="KI Assistent" oninput="updatePreview()">
                            </div>
                            <div class="ki-field">
                                <label for="ki_bubble_icon">Button-Symbol</label>
                                <select name="ki_bubble_icon" id="ki_bubble_icon" class="ki-select" onchange="updatePreview()">
                                    <option value="chat" <?= ($this->kiBubbleIcon ?? '') === 'chat' ? 'selected' : '' ?>>Chat-Blase</option>
                                    <option value="sparkle" <?= ($this->kiBubbleIcon ?? '') === 'sparkle' ? 'selected' : '' ?>>Sparkle / KI</option>
                                    <option value="bot" <?= ($this->kiBubbleIcon ?? '') === 'bot' ? 'selected' : '' ?>>Roboter</option>
                                </select>
                            </div>
                        </div>

                        <div class="ki-field">
                            <label for="ki_welcome_message">Willkommensnachricht</label>
                            <input type="text" name="ki_welcome_message" id="ki_welcome_message" class="ki-input" style="max-width:100%"
                                value="<?= \Contao\StringUtil::specialchars($this->kiWelcomeMessage ?? 'Hallo! Wie kann ich Ihnen helfen?') ?>"
                                placeholder="Hallo! Wie kann ich Ihnen helfen?">
                        </div>

                        <div class="ki-field">
                            <label for="ki_custom_css">Eigene CSS-Anpassungen (Button)</label>
                            <input type="text" name="ki_custom_css" id="ki_custom_css" class="ki-input ki-input-mono" style="max-width:100%"
                                value="<?= \Contao\StringUtil::specialchars($this->kiCustomCss ?? '') ?>"
                                placeholder="z.B. bottom:80px;right:40px">
                            <p class="help">Eigene CSS-Eigenschaften für den Chat-Button, z.B. <code>bottom:80px;right:40px</code> um die Position anzupassen.</p>
                        </div>

                        <!-- Live Preview -->
                        <div class="ki-preview" id="ki_preview">
                            <p style="font-size:12px;font-weight:600;color:#6b7280;margin:0 0 12px">Vorschau</p>
                            <div style="display:flex;align-items:center;gap:16px">
                                <div class="ki-preview-bubble" id="preview_bubble">
                                    <svg id="icon_chat" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 20.105V4.125A1.875 1.875 0 015.625 2.25h12.75A1.875 1.875 0 0120.25 4.125v11.25a1.875 1.875 0 01-1.875 1.875H7.875L3.75 20.105z"/></svg>
                                    <svg id="icon_sparkle" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
                                    <svg id="icon_bot" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>
                                </div>
