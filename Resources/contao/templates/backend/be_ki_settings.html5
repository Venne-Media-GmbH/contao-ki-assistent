<style>
        .ki-card{background:transparent;border:1px solid rgba(128,128,128,.25);border-radius:12px;padding:24px;margin-bottom:20px}
        .ki-card h3{margin:0 0 4px;font-size:15px;font-weight:700}
        .ki-card p.desc{margin:0 0 16px;font-size:13px;opacity:.6}
        .ki-field{margin-bottom:16px}
        .ki-field label{display:block;font-size:13px;font-weight:600;margin-bottom:6px}
        .ki-field .help{font-size:11px;opacity:.5;margin-top:4px}
        .ki-field .help a{color:inherit;text-decoration:underline}
        .ki-input{width:100%;max-width:500px;padding:8px 12px;border:1px solid rgba(128,128,128,.3);border-radius:8px;font-size:13px;outline:none;transition:border-color .15s;background:transparent;color:inherit}
        .ki-input:focus{border-color:#10b981;box-shadow:0 0 0 3px rgba(16,185,129,.15)}
        .ki-input-mono{font-family:ui-monospace,monospace}
        .ki-select{padding:8px 12px;border:1px solid rgba(128,128,128,.3);border-radius:8px;font-size:13px;background:transparent;color:inherit;outline:none;min-width:200px}
        .ki-select:focus{border-color:#10b981}
        .ki-select option{background:#1a1a2e;color:#e0e0e0}
        .ki-row{display:flex;gap:16px;flex-wrap:wrap}
        .ki-row .ki-field{flex:1;min-width:200px}
        .ki-toggle{position:relative;display:inline-flex!important;align-items:center;cursor:pointer;gap:12px}
        .ki-toggle input[type=checkbox]{position:absolute!important;opacity:0!important;width:0!important;height:0!important;margin:0!important;padding:0!important;pointer-events:none!important;appearance:none!important;-webkit-appearance:none!important}
        .ki-toggle .slider{display:inline-block!important;width:44px!important;height:24px!important;background:rgba(128,128,128,.4)!important;border-radius:12px!important;transition:background .2s;position:relative!important;flex-shrink:0!important}
        .ki-toggle .slider::after{content:''!important;position:absolute!important;top:2px!important;left:2px!important;width:20px!important;height:20px!important;background:#fff!important;border-radius:50%!important;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.15)!important}
        .ki-toggle input[type=checkbox]:checked+.slider{background:#10b981!important}
        .ki-toggle input[type=checkbox]:checked+.slider::after{transform:translateX(20px)!important}
        .ki-toggle .label{font-size:14px;font-weight:600}
        .ki-toggle .sublabel{font-size:12px;opacity:.6;font-weight:400}
        .ki-color-row{display:flex;align-items:center;gap:10px}
        .ki-color-picker{width:48px;height:36px;padding:2px;border:1px solid rgba(128,128,128,.3);border-radius:8px;cursor:pointer;background:transparent}
        .ki-btn{padding:10px 24px;background:#10b981;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:background .15s}
        .ki-btn:hover{background:#059669}
        .ki-btn-sm{padding:6px 12px;font-size:12px}
        .ki-status{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600}
        .ki-status.on{background:rgba(16,185,129,.15);color:#34d399}
        .ki-status.off{background:rgba(239,68,68,.15);color:#f87171}
        .ki-status .dot{width:8px;height:8px;border-radius:50%}
        .ki-status.on .dot{background:#10b981}
        .ki-status.off .dot{background:#ef4444}
        .ki-preview{border:1px solid rgba(128,128,128,.25);border-radius:12px;padding:16px;background:rgba(128,128,128,.08);margin-top:16px}
        .ki-preview-bubble{width:48px;height:48px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 2px 8px rgba(0,0,0,.15);overflow:hidden}
        .ki-preview-bubble svg{width:22px;height:22px}
        .ki-preview-bubble img{width:100%;height:100%;object-fit:cover}
        .ki-preview-header{display:inline-flex;align-items:center;padding:10px 16px;border-radius:10px;color:#fff;font-weight:700;font-size:14px;margin-top:12px}
        .ki-hours-list{display:flex;flex-direction:column;gap:8px;max-width:560px}
        .ki-hours-row{display:flex;align-items:center;gap:14px;padding:8px 12px;border:1px solid rgba(128,128,128,.2);border-radius:8px;background:rgba(128,128,128,.04)}
        .ki-hours-row .day-label{font-size:13px;font-weight:600;width:100px;flex-shrink:0}
        .ki-hours-row .day-toggle{flex-shrink:0}
        .ki-hours-row .time-spacer{flex:1}
        .ki-hours-row .time-input{padding:6px 10px;border:1px solid rgba(128,128,128,.3);border-radius:6px;background:transparent;color:inherit;font-size:13px;width:100px;font-family:ui-monospace,monospace;text-align:center}
        .ki-hours-row .time-input:disabled{opacity:.35;cursor:not-allowed}
        .ki-hours-row .time-sep{font-size:13px;opacity:.5}
        .ki-hours-row .status-text{font-size:12px;opacity:.55;width:60px;text-align:right}
        .ki-mini-toggle{position:relative!important;display:inline-block!important;width:38px!important;height:22px!important;flex-shrink:0!important;vertical-align:middle}
        .ki-mini-toggle input[type=checkbox]{position:absolute!important;opacity:0!important;width:0!important;height:0!important;margin:0!important;padding:0!important;pointer-events:none!important;appearance:none!important;-webkit-appearance:none!important}
        .ki-mini-toggle .slider{position:absolute!important;inset:0!important;background:rgba(128,128,128,.4)!important;border-radius:11px!important;transition:background .2s;cursor:pointer;display:block!important}
        .ki-mini-toggle .slider::after{content:''!important;position:absolute!important;top:2px!important;left:2px!important;width:18px!important;height:18px!important;background:#fff!important;border-radius:50%!important;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.15)!important}
        .ki-mini-toggle input[type=checkbox]:checked+.slider{background:#10b981!important}
        .ki-mini-toggle input[type=checkbox]:checked+.slider::after{transform:translateX(16px)!important}
        .ki-logo-row{display:flex;gap:8px;align-items:center}
        .ki-logo-preview{width:48px;height:48px;border-radius:10px;border:1px solid rgba(128,128,128,.3);background:rgba(128,128,128,.08);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
        .ki-logo-preview img{width:100%;height:100%;object-fit:cover}
        .ki-logo-preview .empty{font-size:10px;opacity:.4}
    </style>

